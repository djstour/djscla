# Supabase (project: djscla)
# Dashboard: https://supabase.com/dashboard/project/pmdfdkhfkjyuvucsfsoe
SUPABASE_URL=https://pmdfdkhfkjyuvucsfsoe.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Set at project creation — never commit .env
# SUPABASE_DB_PASSWORD=

# Bókun — server-only. Production: Vercel → Environment Variables (Sensitive; not readable via `vercel env pull`).
# Local: paste the same key pair into .env.local (from Bókun → Settings → API keys).
# BOKUN_ACCESS_KEY=
# BOKUN_SECRET_KEY=
BOKUN_API_HOST=https://api.bokun.io
BOKUN_LANG=EN
BOKUN_CURRENCY=USD

# REST v2 catalog — marketplace contract filter + optional extra product IDs
# BOKUN_V2_CONTRACT_STATUS=ACCEPTED
# BOKUN_V2_EXTRA_EXPERIENCE_IDS=
# BOKUN_V2_CATALOG_CONCURRENCY=10
# BOKUN_V2_DISCOVERY_CACHE_MS=300000
# Serve catalog + list from Supabase (run Admin catalog sync first)
CATALOG_SOURCE=db

# Reseller shop host for Bókun hosted checkout (Step 3 redirect target).
# Find this URL by opening Bókun back-office → Sales Tools → Booking Engine.
# Example: https://djs-tour.bokun.io
BOKUN_SHOP_URL=https://djs-tour.bokun.io

# Marketplace cancellation: v2 policy list may omit supplier policies; fall back to
# GET /activity.json/{id} cancellationPolicy only (set 0 to disable).
# BOKUN_CANCELLATION_V1_FALLBACK=1
# BOKUN_EXTRAS_V1_FALLBACK=1
# BOKUN_TICKET_INFO_V1_FALLBACK=1

# Sandbox only (do not use with production keys):
# BOKUN_API_HOST=https://api.bokuntest.com

# OpenAI — server-only; used by POST /api/translations/sync (prod/cron).
# Local preview: omit OPENAI_API_KEY — use shared Supabase translations (see docs/TRANSLATIONS.md).
# OPENAI_API_KEY=
# OPENAI_TRANSLATION_MODEL=gpt-4o-mini

# Protect translation sync in production (Bearer token)
# TRANSLATION_SYNC_SECRET=

# Vercel Cron (auto translation) — Vercel may inject CRON_SECRET when crons are enabled;
# you can set the same value as TRANSLATION_SYNC_SECRET. Optional batch size per run (default 5).
# CRON_SECRET=
# Translation cron — target full hant+hans catalog within ~12h (~140 SKUs).
# vercel.json: */15 * * * * (48 runs/day). Cap per activity avoids 300s timeout.
# TRANSLATION_CRON_MAX_ACTIVITIES=12
# TRANSLATION_CRON_MAX_TRANSLATIONS_PER_ACTIVITY=10

# Admin console — Phase 1 (read-only).
# Required to enable /admin. Single shared secret; rotate by changing this value.
# Pick a strong random string (24+ chars). Operators sign in once, password lives in sessionStorage.
# ADMIN_PASSWORD=

# Catalog cache (Phase B) — mirror Bókun contract products into Supabase.
# CATALOG_SOURCE=bokun       # only for debugging live v2 fetch (?source=bokun)
# CATALOG_SYNC_MAX_MS=270000   # serverless time budget for /api/admin/sync (default 270s of 300s max)
# CATALOG_SYNC_DETAIL_MS=3200   # estimated ms per detail fetch for batch cap math
# CATALOG_SYNC_SECRET=       # optional fallback secret for POST /api/catalog/sync (CRON_SECRET preferred)
# CATALOG_DETAIL_TTL_MS=     # detail cache freshness, default 21600000 (6h); falls back to live Bókun when older
# CATALOG_SYNC_IMAGES=1      # also mirror Bókun images into Supabase Storage during catalog sync
# SUPABASE_IMAGE_BUCKET=activity-images
