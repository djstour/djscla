{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/translations/cron",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/catalog/sync",
      "schedule": "15 */2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/bokun/activities",
      "destination": "/api/catalog/activities"
    },
    {
      "source": "/",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/tours",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/tours/:slug*",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/journal",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/trip",
      "destination": "/ui_kits/web/index.html"
    },
    {
      "source": "/checkout",
      "destination": "/ui_kits/web/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/ui_kits/web/index.html",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/kit",
      "destination": "/",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.jsx",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/javascript; charset=utf-8"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/api/media/thumb",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
